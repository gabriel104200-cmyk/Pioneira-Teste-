<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Sistema</title>

  <!-- ✅ Ajuste BASE_PATH para o nome do seu repo no Pages -->
  <script>
    // Se seu site for: https://SEUUSUARIO.github.io/Pioneira/
    // então BASE_PATH = "/Pioneira"
    const BASE_PATH = "/PIONEIRA";
  </script>

  <link rel="manifest" href="./manifest.json">
  <meta name="theme-color" content="#2c1a4d" />

  <style>
    :root{
      --bg:#0f1116; --panel:#141823; --panel2:#10131c;
      --text:#e8eaf0; --muted:#9aa3b2; --line:#253042;
      --accent:#7c3aed; --accent2:#22c55e; --warn:#ef4444;
      --radius:14px;
      --shadow: 0 10px 30px rgba(0,0,0,.35);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }
    *{box-sizing:border-box}
    body{margin:0;background:linear-gradient(180deg,#0b0d12, #0f1116);color:var(--text)}
    a{color:inherit}
   .wrap{max-width:1600px;margin:0 auto;padding:18px}
    .topbar{
      display:flex;align-items:center;justify-content:space-between;gap:12px;
      background:rgba(20,24,35,.7);border:1px solid var(--line);
      padding:14px 16px;border-radius:var(--radius);box-shadow:var(--shadow);
      position:sticky;top:10px;backdrop-filter: blur(10px);
    }
    .brand{display:flex;align-items:center;gap:10px}
    .pill{font-size:12px;color:var(--muted);border:1px solid var(--line);padding:4px 10px;border-radius:999px;background:rgba(16,19,28,.55)}
    .btn{cursor:pointer;border:1px solid var(--line);background:rgba(16,19,28,.9);color:var(--text);
      padding:10px 12px;border-radius:12px;font-weight:600}
    .btn:hover{border-color:#3b4a66}
    .btn.primary{background:linear-gradient(135deg,var(--accent),#4c1d95);border-color:transparent}
    .btn.good{background:linear-gradient(135deg,#16a34a,#14532d);border-color:transparent}
    .btn.warn{background:linear-gradient(135deg,#ef4444,#7f1d1d);border-color:transparent}
    .grid{display:grid;grid-template-columns:280px 1fr;gap:14px;margin-top:14px}
    .card{background:rgba(20,24,35,.75);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
    .card h2{margin:0 0 10px 0;font-size:18px}
    .side{padding:14px}
    .main{
  padding:14px;
  min-height:calc(100vh - 160px);
}
    .nav a{
      display:flex;align-items:center;justify-content:space-between;
      padding:10px 12px;border-radius:12px;text-decoration:none;
      color:var(--text);border:1px solid transparent
    }
    .nav a:hover{background:rgba(16,19,28,.7);border-color:var(--line)}
    .nav a.active{background:rgba(124,58,237,.15);border-color:rgba(124,58,237,.35)}
    .muted{color:var(--muted);font-size:13px}
    .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .sep{height:1px;background:var(--line);margin:12px 0}
    textarea,input,select{
      width:100%;background:rgba(16,19,28,.9);border:1px solid var(--line);
      color:var(--text);border-radius:12px;padding:10px 12px;outline:none
    }
    textarea{min-height:150px;resize:vertical}
    table{width:100%;border-collapse:collapse;margin-top:10px;font-size:13px}
    th,td{border-bottom:1px solid rgba(37,48,66,.6);padding:8px 6px;text-align:left}
    th{color:var(--muted);font-weight:700}
    .kpi{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:10px}
    .kpi .box{padding:12px;border:1px solid var(--line);border-radius:14px;background:rgba(16,19,28,.55)}
    .kpi .val{font-size:22px;font-weight:900;margin-top:6px}
    .tag{font-size:12px;padding:3px 8px;border-radius:999px;border:1px solid var(--line);color:var(--muted)}
    .toast{position:fixed;right:16px;bottom:16px;max-width:360px;z-index:9999}
    .toast .t{background:rgba(20,24,35,.9);border:1px solid var(--line);border-radius:14px;padding:12px 12px;margin-top:8px;box-shadow:var(--shadow)}
    .bad{color:#fecaca}
    .ok{color:#bbf7d0}
    .tiny{font-size:12px}
    .hidden{display:none}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div style="font-size:18px;font-weight:900">Sistema Estoque</div>
        <span class="pill" id="ver">v1.0</span>
      </div>
      <div class="row">
        <span class="tag" id="userTag">Deslogado</span>
        <button class="btn" id="btnLogout">Sair</button>
      </div>
    </div>

    <div class="grid">
      <div class="card side">
        <div class="row" style="justify-content:space-between">
          <div style="font-weight:900">⚙️ Menu</div>
          <span class="muted">Painel</span>
        </div>
        <div class="sep"></div>

        <div class="nav" id="nav">
          <a href="#inicio" data-view="inicio" class="active">Início <span class="muted">›</span></a>
          <a href="#transferencia" data-view="transferencia">Transferência <span class="muted">Editar</span></a>
          <a href="#zeramento" data-view="zeramento">Zeramento <span class="muted">Editar</span></a>
          <a href="#requisicao" data-view="requisicao">Requisições <span class="muted">›</span></a>
          <a href="#manual" data-view="manual">✍️ Manual <span class="muted">›</span></a>
          <a href="#exs" data-view="exs">⚖️ Entrada x Saída <span class="muted">›</span></a>
          <a href="#conferencia" data-view="conferencia">Conferência <span class="muted">›</span></a>
          <a href="#producao" data-view="producao">Conf. Estoque <span class="muted">Abrir</span></a>
          <a href="#admin" data-view="admin">🛠️ Admin <span class="muted">Controle</span></a>
        </div>

        <div class="sep"></div>
        <div class="muted tiny">
          ✅ Tudo roda no navegador (offline).<br/>
          ⚠️ Não é sistema “server”, é painel/apoio.
           👤 Criado por Gabriel Andrade.
        </div>
      </div>

      <div class="card main">
        <!-- LOGIN -->
        <div id="loginBox" class="hidden">
          <h2>🔐 Login</h2>
          <p class="muted">Entre para acessar o painel (usuário/senha ficam salvos no navegador).</p>
          <div class="row">
            <div style="flex:1">
              <label class="muted">Usuário</label>
              <input id="lgUser" placeholder="ex: gabriel" />
            </div>
            <div style="flex:1">
              <label class="muted">Senha</label>
              <input id="lgPass" type="password" placeholder="••••••••" />
            </div>
          </div>
          <div class="row" style="margin-top:10px">
            <button class="btn primary" id="btnLogin">Entrar</button>
            <button class="btn" id="btnCreate">Criar conta</button>
            <button class="btn" id="btnRecover">Recuperar senha</button>
          </div>

          <div class="sep"></div>

          <div id="createBox" class="hidden">
            <h2>🧾 Criar conta</h2>
            <div class="row">
              <div style="flex:1"><label class="muted">Usuário</label><input id="crUser"></div>
              <div style="flex:1"><label class="muted">Senha</label><input id="crPass" type="password"></div>
              <div style="flex:1"><label class="muted">Email</label><input id="crEmail" type="email"></div>
            </div>
            <div class="row" style="margin-top:10px">
              <button class="btn good" id="btnDoCreate">Cadastrar</button>
              <button class="btn" onclick="toggleBox('createBox', false)">Voltar</button>
            </div>
          </div>

          <div id="recoverBox" class="hidden">
            <h2>📨 Recuperar senha</h2>
            <div style="max-width:420px">
              <label class="muted">Usuário</label>
              <input id="rcUser" placeholder="usuário cadastrado">
            </div>
            <div class="row" style="margin-top:10px">
              <button class="btn primary" id="btnDoRecover">Enviar</button>
              <button class="btn" onclick="toggleBox('recoverBox', false)">Voltar</button>
            </div>
            <p class="muted tiny">Obs: aqui só mostra a dica porque é tudo local.</p>
          </div>
        </div>

        <!-- VIEWS -->
        <div id="views" class="hidden">

          <!-- INÍCIO -->
          <section data-section="inicio">
            <h2>🏠 Início</h2>
            <p class="muted">Resumo do “Entrada x Saída”.</p>

        <div class="kpi">
  <div class="box">
    <div class="muted">Total (teórico)</div>
    <div class="val" id="kTotal">—</div>
  </div>
  <div class="box">
    <div class="muted">Real</div>
    <div class="val" id="kReal">—</div>
  </div>
  <div class="box">
    <div class="muted">Diferença</div>
    <div class="val" id="kDiff">—</div>
  </div>
</div>

<div class="muted tiny" style="margin-top:8px" id="kDataInfo">Nenhum dia selecionado.</div>

            <div class="row" style="margin-top:10px">
              <button class="btn primary" onclick="abrirExsDiaSelecionado()">Abrir Entrada x Saída</button>
              <button class="btn" onclick="refreshResumo()">Atualizar painel</button>
              <button class="btn good" onclick="marcarHoje()">Marcar hoje (bateu)</button>
            </div>

            <div class="sep"></div>
            <div class="muted">✅ toda vez que a diferença ficar 0, você pode marcar o dia como “bateu”.</div>
            <div style="margin-top:10px" id="cal"></div>
          </section>

          <!-- TRANSFERÊNCIA -->
          <section data-section="transferencia" class="hidden">
            <h2>🔁 Transferência</h2>
            <p class="muted">Cole seus dados (CSV/planilha copiada) e clique em Importação.</p>
            <textarea id="txTransfer" placeholder="Código;Descrição;Grade1;Grade2;Grade3;QTD1;QTD2;QTD3;Local;Destino"></textarea>
            <div class="row" style="margin-top:10px">
              <button class="btn primary" onclick="importarTabela('transfer')">Importação</button>
              <button class="btn" onclick="limparTabela('transfer')">Limpar</button>
              <button class="btn" onclick="baixarTxt('transfer')">Baixar TXT</button>
            </div>
            <div id="tbTransfer"></div>
          </section>

          <!-- ZERAMENTO -->
          <section data-section="zeramento" class="hidden">
            <h2>🧹 Zeramento</h2>
            <p class="muted">Cole e importe.</p>
            <textarea id="txZero" placeholder="Código;Descrição;Grade1;Grade2;Grade3;QTD1;QTD2;QTD3;Local"></textarea>
            <div class="row" style="margin-top:10px">
              <button class="btn primary" onclick="importarTabela('zero')">Importação</button>
              <button class="btn" onclick="limparTabela('zero')">Limpar</button>
              <button class="btn" onclick="baixarTxt('zero')">Baixar TXT</button>
            </div>
            <div id="tbZero"></div>
          </section>

          <!-- REQUISIÇÃO -->
          <section data-section="requisicao" class="hidden">
            <h2>📌 Requisição</h2>
            <p class="muted">Cole vários pedidos que o sistema separa pelo número do pedido e importe.</p>
            <textarea id="txReq" placeholder="Pedido;Cliente;Código;Item;Grade1;Grade2;Grade3;Qtd"></textarea>
            <div class="row" style="margin-top:10px">
              <button class="btn primary" onclick="importarTabela('req')">Importação</button>
              <button class="btn" onclick="limparTabela('req')">Limpar</button>
              <button class="btn" onclick="baixarTxt('req')">Baixar TXT</button>
            </div>
            <div id="tbReq"></div>
          </section>

          <!-- MANUAL -->
          <section data-section="manual" class="hidden">
            <h2>✍️ Requisição Manual</h2>
            <p class="muted">Cole ou digite a requisição manual.</p>
            <textarea id="txManual" placeholder="Digite aqui..."></textarea>
            <div class="row" style="margin-top:10px">
              <button class="btn primary" onclick="salvarManual()">Importar RI</button>
              <button class="btn" onclick="limparManual()">Limpar</button>
            </div>
            <div class="sep"></div>
            <div class="muted tiny">Salvo no navegador.</div>
          </section>

          <!-- ENTRADA x SAÍDA -->
          <section data-section="exs" class="hidden">
            <h2>⚖️ Entrada x Saída</h2>
            <p class="muted">Controle simples: Saldo inicial + Entrada - Saída + Ajuste.</p>

            <div class="row">
  <div style="flex:1">
    <label class="muted">Saldo inicial do mês</label>
    <input id="exSaldo" type="number" step="any" value="0">
  </div>
  <div style="flex:1">
    <label class="muted">Entrada</label>
    <input id="exEntrada" type="number" step="any" value="0">
  </div>
  <div style="flex:1">
    <label class="muted">Saída</label>
    <input id="exSaida" type="number" step="any" value="0">
  </div>
  <div style="flex:1">
    <label class="muted">Real</label>
    <input id="exRealInput" type="number" step="any" value="0">
  </div>
  <div style="flex:1">
    <label class="muted">Ajuste</label>
    <input id="exAjuste" type="number" step="any" value="0">
  </div>
</div>

            <div class="row" style="margin-top:10px">
              <button class="btn good" onclick="calcEXS()">Aplicar</button>
              <button class="btn primary" onclick="salvarEXS()">Salvar</button>
              <button class="btn" onclick="limparEXS()">Limpar</button>
            </div>

            <div class="kpi">
              <div class="box"><div class="muted">Total</div><div class="val" id="exTotal">0</div></div>
              <div class="box"><div class="muted">Real</div><div class="val" id="exReal">0</div></div>
              <div class="box"><div class="muted">Diferença</div><div class="val" id="exDiff">0</div></div>
            </div>

            <div class="sep"></div>
            <div class="muted tiny">
              ✅ Diferença 0 = bateu. Diferença positiva = entrou mais que o esperado. Diferença negativa = faltou entrada.
            </div>
          </section>

          <!-- CONFERÊNCIA -->
          <section data-section="conferencia" class="hidden">
            <h2>✅ Conferência de Locais</h2>
           <p class="muted">Cole a planilha de estoque para comparativo de saldo.</p>

            <div class="row">
              <div style="flex:1">
                <label class="muted">Cadastro (Código → Local correto)</label>
                <textarea id="txCad" placeholder="CÓDIGO;DESCRIÇÃO;GRADE1;GRADE2;GRADE3;QUANTIDADE"></textarea>
              </div>
              <div style="flex:1">
                <label class="muted">Planilha informada (Código → Local informado)</label>
               <textarea id="txInf" placeholder="CÓDIGO;DESCRIÇÃO;GRADE1;GRADE2;GRADE3;QUANTIDADE"></textarea>
              </div>
            </div>

            <div class="row" style="margin-top:10px">
              <button class="btn primary" onclick="analisarConferencia()">Analisar</button>
              <button class="btn" onclick="limparConferencia()">Limpar</button>
              <button class="btn" onclick="baixarErrosConferencia()">Baixar erros (TXT)</button>
            </div>

            <div id="tbConf"></div>
          </section>

         <!-- CONF. ESTOQUE -->
<section data-section="producao" class="hidden">
  <h2>📦 Conf. Estoque</h2>
  <p class="muted">Cole a planilha completa do estoque. O sistema vai identificar produtos em local divergente com base no local padrão do próprio código.</p>

  <div class="row">
    <div style="flex:1">
      <label class="muted">Planilha de estoque</label>
      <textarea id="txProdA" placeholder="LOCAL;CODIGO PRODUTO;DESCRICAO;GRADE1;GRADE2;GRADE3;QUANTIDADE"></textarea>
    </div>
  </div>

  <div class="row" style="margin-top:10px">
    <button class="btn primary" onclick="conferirProducao()">Analisar</button>
    <button class="btn" onclick="limparProducao()">Limpar</button>
  </div>

  <div id="tbProd"></div>
</section>

          <!-- ADMIN -->
          <section data-section="admin" class="hidden">
            <h2>🛠️ Admin</h2>
            <p class="muted">Controles locais (email, permissões e manutenção).</p>

            <div style="max-width:520px">
              <label class="muted">Email (somente registro local)</label>
              <input id="adEmail" type="email" placeholder="seuemail@exemplo.com">
              <div class="row" style="margin-top:10px">
                <button class="btn primary" onclick="salvarEmail()">Salvar Email</button>
                <button class="btn" onclick="carregarEmail()">Recarregar</button>
                <button class="btn warn" onclick="resetTudo()">Resetar tudo</button>
              </div>
            </div>

            <div class="sep"></div>
            <div class="muted tiny">
              Se você quiser deixar isso “de verdade” (com login real e banco), dá pra ligar num Google Apps Script / Firebase depois.
            </div>
          </section>

        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
  // ---------- Utils ----------
  const $ = (s) => document.querySelector(s);
  const $$ = (s) => Array.from(document.querySelectorAll(s));
  const LS = (k, v) => v === undefined ? localStorage.getItem(k) : localStorage.setItem(k, v);
  const LSJ = (k, v) => v === undefined ? JSON.parse(localStorage.getItem(k) || "null") : localStorage.setItem(k, JSON.stringify(v));

  function toast(msg, ok=true){
    const el = document.createElement("div");
    el.className = "t";
    el.innerHTML = `<div style="font-weight:900" class="${ok?'ok':'bad'}">${ok?'Aviso':'Erro'}</div>
                    <div class="muted">${msg}</div>`;
    $("#toast").appendChild(el);
    setTimeout(()=>{el.remove()}, 4500);
  }

function parseLines(text){
  const lines = (text||"").trim().split(/\r?\n/).filter(Boolean);
  // IMPORTANTE: não dividir por vírgula, porque existe "0,45mm" na descrição
  return lines.map(l => l.split(/[;\t]/).map(x => x.trim()));
}

  function renderTable(headers, rows, opts={}){
    const { highlightFn } = opts;
    let html = `<table><thead><tr>${headers.map(h=>`<th>${h}</th>`).join("")}</tr></thead><tbody>`;
    for (const r of rows){
      const klass = highlightFn ? (highlightFn(r) ? ' style="background:rgba(239,68,68,.12)"' : '') : '';
      html += `<tr${klass}>${r.map(c=>`<td>${escapeHtml(String(c ?? ""))}</td>`).join("")}</tr>`;
    }
    html += `</tbody></table>`;
    return html;
  }

  function escapeHtml(s){
    return s.replace(/[&<>"']/g, (m)=>({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;" }[m]));
  }

  // ---------- Auth (local) ----------
  function toggleBox(id, show){ $("#"+id).classList.toggle("hidden", !show); }
  function getUsers(){ return LSJ("users") || []; }
  function setUsers(u){ LSJ("users", u); }

  function login(u,p){
    const users = getUsers();
    const found = users.find(x=>x.user===u && x.pass===p);
    if(!found){ toast("Usuário ou senha inválidos.", false); return false; }
    LS("session", u);
    setupUI();
    toast("Logado com sucesso.");
    return true;
  }

  function logout(){
    localStorage.removeItem("session");
    setupUI();
    toast("Saiu do sistema.");
  }

  function setupUI(){
    const u = LS("session");
    $("#userTag").textContent = u ? `👤 ${u}` : "Deslogado";
    $("#btnLogout").disabled = !u;

    $("#loginBox").classList.toggle("hidden", !!u);
    $("#views").classList.toggle("hidden", !u);

    if(u){ refreshResumo(); montarCalendario(); }
  }

  // ---------- Navigation ----------
  function goto(view){
    location.hash = "#"+view;
    setView(view);
  }

  function setView(view){
    $$("#nav a").forEach(a => a.classList.toggle("active", a.dataset.view===view));
    $$("[data-section]").forEach(s => s.classList.toggle("hidden", s.dataset.section !== view));
  }

  window.addEventListener("hashchange", ()=>{
    const v = (location.hash||"#inicio").replace("#","");
    setView(v);
  });

  // ---------- Data actions ----------
  function importarTabela(kind){
    const map = {
      transfer: { tx:"#txTransfer", out:"#tbTransfer", headers:["Código","Descrição","Chave5","Chave6","Chave7","QTD1","QTD2","QTD3","Local","Destino"] },
      zero:     { tx:"#txZero", out:"#tbZero", headers:["Código","Descrição","Chave5","Chave6","Chave7","QTD1","QTD2","QTD3","Local"] },
      req:      { tx:"#txReq", out:"#tbReq", headers:["Pedido","Cliente","Código","Item","Chave5","Chave6","Chave7","Qtd"] },
    };
    const cfg = map[kind];
    const rows = parseLines($(cfg.tx).value);
    if(!rows.length){ toast("Nada para importar.", false); return; }
    LSJ("tab_"+kind, rows);
    $(cfg.out).innerHTML = renderTable(cfg.headers, rows);
    toast("Importação concluída.");
  }

 function limparTabela(kind){

  // limpa o texto colado
  if(kind==="transfer") $("#txTransfer").value = "";
  if(kind==="zero") $("#txZero").value = "";
  if(kind==="req") $("#txReq").value = "";

  // limpa dados da tabela
  LSJ("tab_"+kind, []);

  if(kind==="transfer") $("#tbTransfer").innerHTML="";
  if(kind==="zero") $("#tbZero").innerHTML="";
  if(kind==="req") $("#tbReq").innerHTML="";

  toast("Texto e tabela limpos.");
}
  
  // ===== Zeramento: aprende aos poucos (pergunta só o que não conhece) =====
 function zeroMapToken(token){
  const t0 = (token ?? "").toString().trim();
  if (!t0) return "";

  const map = LSJ("zero_map") || {};
  const key = t0.toLowerCase();

  // 1) Se já tem no mapa, usa
  if (map[key]) return map[key];

  // 2) Aliases automáticos (corrige ROS -> ROSA etc.)
  const aliases = {
    "ros": "ROSA",
    "rosa": "ROSA",
    "fume": "FUME",   // se o ERP aceitar FUMÊ, troque aqui
    "lar": "LAR",
    "pre": "PRE",
  };
  if (aliases[key]){
    map[key] = aliases[key];
    LSJ("zero_map", map);
    return map[key];
  }

  // 3) Números (ex: 304, 296) passam direto
  if (/^[0-9]+$/.test(t0)){
    map[key] = t0;
    LSJ("zero_map", map);
    return t0;
  }

  // 4) Só aceita automático se for tamanho/código curto conhecido
  const knownShort = /^(P|M|G|GG|XG|XGG|XXG|PP|PM|46|48|50|52|54|56|58|60|41|42|43|44|45|PRE|AMO|MASC|FEM)$/i;
  if (knownShort.test(t0)){
    map[key] = t0.toUpperCase();
    LSJ("zero_map", map);
    return map[key];
  }

  // 5) Se for texto "grande" (ex: PARANA, XINGU, PANAMA) OBRIGA cadastrar
  // (para você digitar 304 / 296 / etc.)
  let resp = "";
  while(!resp){
    resp = (prompt(`ZERAMENTO: Como "${t0}" deve sair no TXT? (ex: 304 / 296 / 5279 / etc.)`) || "").trim();
    if(!resp) alert(`Você precisa cadastrar "${t0}" para o TXT sair correto.`);
  }

  map[key] = resp;
  LSJ("zero_map", map);
  return resp;
}
  
function baixarTxt(kind){
  const rows = LSJ("tab_"+kind) || [];
  if(!rows.length){ toast("Nada para baixar.", false); return; }

  // helpers (disponível para todos os tipos)
  function toNumberBR(x){
    const s = (x ?? "").toString().trim().replace(/\./g,"").replace(",",".");
    const n = Number(s);
    return Number.isFinite(n) ? n : 0;
  }
  function fmtBR(n){
    return n.toFixed(2).replace(".", ",");
  }

  // data atual
  const hoje = new Date();
  const dd = String(hoje.getDate()).padStart(2,"0");
  const mm = String(hoje.getMonth()+1).padStart(2,"0");
  const yyyy = hoje.getFullYear();
  const data = `${dd}/${mm}/${yyyy}`;

  // ===== REQUISIÇÃO (formato antigo) =====
  if(kind === "req"){
    const departamento = "27";

    let requisitante = LS("req_requisitante");
    if(!requisitante){
      requisitante = prompt("Informe seu REQUISITANTE (ex: 26):");
      if(!requisitante){ toast("Requisitante não informado.", false); return; }
      LS("req_requisitante", requisitante.trim());
    }
    requisitante = requisitante.trim();

    const locais = LSJ("req_locais") || {};

    const byPedido = new Map();
    for(const r of rows){
      const pedido = (r[0] || "").trim();
      if(!pedido) continue;
      if(!byPedido.has(pedido)) byPedido.set(pedido, []);
      byPedido.get(pedido).push(r);
    }
    if(byPedido.size === 0){
      toast("Nenhum pedido válido encontrado.", false);
      return;
    }

    const out = [];

    for(const [pedido, linhas] of byPedido.entries()){
      const cliente = (linhas[0][1] || "").trim();

      out.push([
        "R", data, "1", "1", requisitante, departamento,
        `${pedido}  -  ${cliente}`,
        pedido, "0", "0"
      ].join("|"));

      for(const r of linhas){
        const codigo = (r[2] || "").trim();
        const item   = (r[3] || "").trim();
        const chave5 = (r[4] || "").trim();
        const chave6 = (r[5] || "").trim();
        const qtd    = (r[7] ?? r[6] ?? "").toString().trim();

        if(!codigo || !qtd) continue;

        let local = locais[codigo];
        if(!local){
          local = (prompt(`Local de saída do código ${codigo}:`) || "").trim();
          if(local) locais[codigo] = local;
        }

        out.push(["I","P",codigo,item,chave5,chave6,qtd,"3",local].join("|"));
      }
    }

    LSJ("req_locais", locais);

    const txt = out.join("\r\n") + "\r\n";
    const blob = new Blob([txt], {type:"text/plain;charset=utf-8"});
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `REQ_${data.replaceAll("/","-")}.txt`;
    a.click();
    URL.revokeObjectURL(a.href);

    toast(`TXT gerado com ${byPedido.size} pedido(s) no formato antigo.`);
    return;
  }

  // ===== ZERAMENTO (formato M1/M3 | E/S | data | codigo | g1 | g2 | g3 | local | qtd | vl_unit | vl_total | 1905/5906) =====
  if (kind === "zero") {

    let filial = LS("zero_filial");
    if (!filial) {
      filial = (prompt("Filial do arquivo? Digite 1 ou 3 (vai virar M1 ou M3):", "1") || "").trim();
      if (!["1","3"].includes(filial)) { toast("Filial inválida. Use 1 ou 3.", false); return; }
      LS("zero_filial", filial);
    }

    let precoUnit = LS("zero_preco_unit");
    if (!precoUnit) {
      precoUnit = (prompt("Preço unitário para cálculo (ex: 0,01):", "0,01") || "0,01").trim();
      if (!precoUnit) precoUnit = "0,01";
      LS("zero_preco_unit", precoUnit);
    }

    const precoN = toNumberBR(precoUnit);
    const saidaFinal = "5906";
    const entradaFinal = "1905";
    const prefixoFilial = `M${filial}`;

    const out = [];

    const rowsZero = LSJ("tab_zero") || [];
    if (!rowsZero.length) { toast("Nada para baixar.", false); return; }

    for (const r of rowsZero) {
      if (!r || !r.length) continue;

      const n = r.length;
      if(n < 8) continue;

      const codigo = (r[0] ?? "").toString().trim();
      if(!codigo) continue;

      const local = (r[n - 1] ?? "").toString().trim();
      const divergStr = (r[n - 2] ?? "").toString().trim();

      const g1raw = (r[n - 7] ?? "").toString().trim();
      const g2raw = (r[n - 6] ?? "").toString().trim();
      const g3raw = (r[n - 5] ?? "").toString().trim();

      const diverg = toNumberBR(divergStr);
      if (diverg === 0) continue;

      const tipo = diverg > 0 ? "E" : "S";
      const qtd = Math.abs(diverg);

      const g1 = zeroMapToken(g1raw);
      const g2 = zeroMapToken(g2raw);
      const g3 = zeroMapToken(g3raw);

      if (g2 && !g1) { toast(`Erro: ${codigo} tem Grade 2 mas Grade 1 vazia.`, false); return; }
      if (g3 && !g2) { toast(`Erro: ${codigo} tem Grade 3 mas Grade 2 vazia.`, false); return; }
      if (!local) { toast(`Erro: Local vazio no código ${codigo}`, false); return; }

      const total = qtd * precoN;
      const final = (tipo === "E") ? entradaFinal : saidaFinal;

      out.push([
        prefixoFilial,
        tipo,
        data,
        codigo,
        g1,
        g2,
        g3,
        local,
        String(qtd).replace(".", ","),
        precoUnit,
        fmtBR(total),
        final
      ].join("|"));
    }

    if (!out.length) { toast("Nada para gerar (divergência = 0 em tudo).", false); return; }

    const txt = out.join("\r\n") + "\r\n";
    const blob = new Blob([txt], { type: "text/plain;charset=utf-8" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `ZER_${data.replaceAll("/","-")}.txt`;
    a.click();
    URL.revokeObjectURL(a.href);

    toast("TXT de Zeramento gerado com sucesso.");
    return;
  }

  // ===== TRANSFERÊNCIA (formato ERP) =====
  if (kind === "transfer") {

    let filial = LS("transf_filial");
    if (!filial) {
      filial = (prompt("Filial? (1 ou 3)", "1") || "").trim();
      if (!["1","3"].includes(filial)) { toast("Filial inválida.", false); return; }
      LS("transf_filial", filial);
    }

    const prefixoFilial = `M${filial}`;
    const precoUnit = "0,01";
    const precoN = 0.01;
    const final = "5949";

    const out = [];

    for (const r of rows){
      const codigo = (r[0] || "").trim();

      // layout: 0 codigo | 1 desc | 2 cor | 3 tamanho | 4 g3(vazio) | 5 qtd1 | 6 qtd2 | 7 diverg | 8 local1 | 9 local2
      const g1 = zeroMapToken(r[2]); // cor (ex: Preto -> PRE)
      const g2 = zeroMapToken(r[3]); // tamanho (ex: XGG)
      const g3 = zeroMapToken(r[4]); // normalmente vazio

      const diverg = toNumberBR(r[7]); // -2 / +1
      if (!codigo || diverg === 0) continue;

      const qtd = Math.abs(diverg);

      const local1 = (r[8] || "").trim();
      const local2 = (r[9] || "").trim();
      if(!local1 || !local2) continue;

      // regra do sinal:
      // diverg < 0: tira do local1 -> local2
      // diverg > 0: tira do local2 -> local1
      const localOrigem  = diverg < 0 ? local1 : local2;
      const localDestino = diverg < 0 ? local2 : local1;

      const total = qtd * precoN;

      out.push([
        prefixoFilial,
        "T",
        data,
        codigo,
        g1,
        g2,
        g3,
        localOrigem,
        localDestino,
        String(qtd).replace(".", ","),
        precoUnit,
        fmtBR(total),
        final
      ].join("|"));
    }

    if(!out.length){ toast("Nada para gerar na Transferência.", false); return; }

    const txt = out.join("\r\n") + "\r\n";
    const blob = new Blob([txt], {type:"text/plain;charset=utf-8"});
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `TRANSF_${data.replaceAll("/","-")}.txt`;
    a.click();
    URL.revokeObjectURL(a.href);

    toast("TXT de Transferência gerado.");
    return;
  }

  // ===== fallback =====
  const txt = rows.map(r=>r.join(";")).join("\r\n") + "\r\n";
  const blob = new Blob([txt], {type:"text/plain;charset=utf-8"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = kind + ".txt";
  a.click();
  URL.revokeObjectURL(a.href);
}
  
function salvarEXS(){
  LSJ("exs", {
    saldo: Number($("#exSaldo").value || 0),
    entrada: Number($("#exEntrada").value || 0),
    saida: Number($("#exSaida").value || 0),
    real: Number($("#exRealInput").value || 0),
    ajuste: Number($("#exAjuste").value || 0)
  });

  calcEXS();
  salvarExsDoDia();
  carregarResumoDoDia(hojeKey());
  montarCalendario();
  toast("Salvo.");
}

  function limparEXS(){
  LSJ("exs", null);
  $("#exSaldo").value = 0;
  $("#exEntrada").value = 0;
  $("#exSaida").value = 0;
  $("#exRealInput").value = 0;
  $("#exAjuste").value = 0;

  $("#exTotal").textContent = 0;
  $("#exReal").textContent = 0;
  $("#exDiff").textContent = 0;

  LSJ("exsResumo", null);
  refreshResumo();
  toast("Zerado.");
}
  
function hojeKey(){
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
}

function formatarDataBR(key){
  if(!key) return "";
  const [y,m,d] = key.split("-");
  return `${d}/${m}/${y}`;
}

function getExsHistorico(){
  return LSJ("exsHistorico") || {};
}

function setExsHistorico(data){
  LSJ("exsHistorico", data);
}

function salvarExsDoDia(){
  const historico = getExsHistorico();
  const key = hojeKey();

  const saldo = Number($("#exSaldo").value || 0);
  const entrada = Number($("#exEntrada").value || 0);
  const saida = Number($("#exSaida").value || 0);
  const real = Number($("#exRealInput").value || 0);
  let ajuste = Number($("#exAjuste").value || 0);
  ajuste = ajuste * -1;

  const total = saldo + entrada - saida;
  const diff = (total - real) + ajuste;

  historico[key] = {
    saldo,
    entrada,
    saida,
    real,
    ajusteDigitado: Number($("#exAjuste").value || 0),
    ajusteAplicado: ajuste,
    total,
    diff
  };

  setExsHistorico(historico);
  LS("exs_selected_day", key);
}

function carregarResumoDoDia(key){
  const historico = getExsHistorico();
  const item = historico[key];

  if(!item){
    $("#kTotal").textContent = "—";
    $("#kReal").textContent = "—";
    $("#kDiff").textContent = "—";
    $("#kDataInfo").textContent = `Sem dados salvos para ${formatarDataBR(key)}.`;
    return;
  }

  $("#kTotal").textContent = item.total ?? "—";
  $("#kReal").textContent = item.real ?? "—";
  $("#kDiff").textContent = item.diff ?? "—";
  $("#kDataInfo").textContent = `Dados salvos em ${formatarDataBR(key)}.`;
}

function abrirExsDiaSelecionado(){
  const key = LS("exs_selected_day") || hojeKey();
  const historico = getExsHistorico();
  const item = historico[key];

  goto("exs");

  if(!item){
    toast(`Não há dados salvos para ${formatarDataBR(key)}.`, false);
    setTimeout(()=>setModoExs(true, key), 50);
    return;
  }

  $("#exSaldo").value = item.saldo ?? 0;
  $("#exEntrada").value = item.entrada ?? 0;
  $("#exSaida").value = item.saida ?? 0;
  $("#exRealInput").value = item.real ?? 0;
  $("#exAjuste").value = item.ajusteDigitado ?? 0;

  calcEXS();

  const isHoje = key === hojeKey();
  setModoExs(isHoje, key);
}

function setModoExs(editavel, key){
  const ids = ["exSaldo","exEntrada","exSaida","exRealInput","exAjuste"];
  ids.forEach(id => {
    const el = $("#"+id);
    if(el) el.disabled = !editavel;
  });

  const infoId = "exsModoInfo";
  let info = $("#"+infoId);
  if(!info){
    info = document.createElement("div");
    info.id = infoId;
    info.className = "muted tiny";
    info.style.marginTop = "8px";
    const alvo = document.querySelector('[data-section="exs"] .kpi');
    if(alvo) alvo.insertAdjacentElement("afterend", info);
  }

  if(editavel){
    info.textContent = `Modo edição liberado para ${formatarDataBR(key)}.`;
  }else{
    info.textContent = `Modo consulta: ${formatarDataBR(key)}. Para alterar, somente o dono do sistema.`;
  }
}
  
  function refreshResumo(){
  const selected = LS("exs_selected_day") || hojeKey();
  carregarResumoDoDia(selected);
}
  
  function marcarHoje(){
  const key = hojeKey();
  const historico = getExsHistorico();

  if(!historico[key]){
    toast("Salve primeiro a Entrada x Saída de hoje antes de marcar como bateu.", false);
    return;
  }

  const map = LSJ("bateu") || {};
  map[key] = !map[key];
  LSJ("bateu", map);

  LS("exs_selected_day", key);
  carregarResumoDoDia(key);
  montarCalendario();

  toast(map[key] ? "Dia de hoje marcado como bateu." : "Marca do dia de hoje removida.");
}

 function montarCalendario(){
  const d = new Date();
  const y = d.getFullYear(), m = d.getMonth();
  const first = new Date(y,m,1);
  const last = new Date(y,m+1,0);
  const bateu = LSJ("bateu") || {};
  const selecionado = LS("exs_selected_day") || hojeKey();
  const hoje = hojeKey();

  let html = `<div class="muted">📅 ${first.toLocaleString("pt-BR",{month:"long"})} / ${y}</div>`;
  html += `<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-top:8px">`;

  const wd = ["Dom","Seg","Ter","Qua","Qui","Sex","Sáb"];
  for(const w of wd){
    html += `<div class="muted tiny" style="text-align:center">${w}</div>`;
  }

  const pad = first.getDay();
  for(let i=0;i<pad;i++) html += `<div></div>`;

  for(let day=1; day<=last.getDate(); day++){
    const key = `${y}-${String(m+1).padStart(2,"0")}-${String(day).padStart(2,"0")}`;
    const on = !!bateu[key] && key <= hoje;
    const ativo = key === selecionado;

    let style = `padding:10px;border-radius:12px;`;

    if(on){
      style += `background:rgba(34,197,94,.18);border-color:rgba(34,197,94,.35);`;
    }

    if(ativo){
      style += `outline:2px solid rgba(255,255,255,.18);`;
    }

    html += `<button class="btn" style="${style}" onclick="selecionarDia('${key}')">${day}</button>`;
  }

  html += `</div>`;
  $("#cal").innerHTML = html;
}

  function selecionarDia(key){
  LS("exs_selected_day", key);
  carregarResumoDoDia(key);
  montarCalendario();
}

function toggleDia(key){
  const map = LSJ("bateu") || {};
  map[key] = !map[key];
  LSJ("bateu", map);
  montarCalendario();
}

function calcEXS(){
  const saldo = Number($("#exSaldo").value || 0);
  const entrada = Number($("#exEntrada").value || 0);
  const saida = Number($("#exSaida").value || 0);
  const real = Number($("#exRealInput").value || 0);

  // ajuste invertido automaticamente
  let ajuste = Number($("#exAjuste").value || 0);
  ajuste = ajuste * -1;

  const total = saldo + entrada - saida;
  const diff = (total - real) + ajuste;

  $("#exTotal").textContent = total;
  $("#exReal").textContent = real;
  $("#exDiff").textContent = diff;

  LSJ("exsResumo", { total, real, diff });
  refreshResumo();
}
  
// Conferência
function analisarConferencia(){
  // Aqui "Cadastro" = Planilha 1 (base)
  // e "Planilha informada" = Planilha 2 (comparação)
  const p1 = parseLines($("#txCad").value);
  const p2 = parseLines($("#txInf").value);

  if(!p1.length || !p2.length){
    toast("Cole as duas planilhas para comparar.", false);
    return;
  }

  // Lê linha no formato:
  // CODIGO | DESCRICAO | G1 | G2 | G3(opcional) | QTD
  // (aceita também quando G3 vem vazio)
  function readItem(r){
    if(!r || !r.length) return null;

    const codigo = (r[0] ?? "").toString().trim();
    if(!codigo) return null;

    const desc  = (r[1] ?? "").toString().trim();
    const g1    = (r[2] ?? "").toString().trim();
    const g2    = (r[3] ?? "").toString().trim();

    // Pode vir: [codigo,desc,g1,g2,"",qtd] ou [codigo,desc,g1,g2,qtd]
    let g3 = "";
    let qtdStr = "";

    if(r.length >= 6){
      g3 = (r[4] ?? "").toString().trim();
      qtdStr = (r[5] ?? "").toString().trim();
    }else{
      g3 = "";
      qtdStr = (r[4] ?? "").toString().trim();
    }

    const qtd = Number((qtdStr || "0").toString().replace(/\./g,"").replace(",", "."));
    const qtdOk = Number.isFinite(qtd) ? qtd : 0;

    const key = [codigo, g1, g2, g3].join("|");
    return { key, codigo, desc, g1, g2, g3, qtd: qtdOk };
  }

  // Soma itens repetidos dentro da mesma planilha
  function buildMap(rows){
    const map = new Map();
    for(const r of rows){
      const it = readItem(r);
      if(!it) continue;

      if(!map.has(it.key)){
        map.set(it.key, { ...it });
      }else{
        map.get(it.key).qtd += it.qtd;
      }
    }
    return map;
  }

  const m1 = buildMap(p1);
  const m2 = buildMap(p2);

  // Local fixo na saída (igual seu exemplo).
  // Se quiser mudar depois, dá pra criar um input ou prompt.
  const local = "2097";

  const keys = new Set([...m1.keys(), ...m2.keys()]);
  const divergRows = [];

  for(const k of keys){
    const a = m1.get(k);
    const b = m2.get(k);

    const codigo = (a?.codigo ?? b?.codigo ?? "");
    const desc   = (a?.desc   ?? b?.desc   ?? "");
    const g1     = (a?.g1     ?? b?.g1     ?? "");
    const g2     = (a?.g2     ?? b?.g2     ?? "");
    const g3     = (a?.g3     ?? b?.g3     ?? "");

    const q1 = a?.qtd ?? 0; // planilha 1
    const q2 = b?.qtd ?? 0; // planilha 2

    // ✅ regra: sempre comparar Planilha2 - Planilha1
    const diff = q2 - q1;

    if(diff !== 0){
      divergRows.push([local, codigo, desc, g1, g2, g3, diff]);
    }
  }

  // Ordena pra ficar bonito
  divergRows.sort((x,y)=>{
    const a = (x[1]||"").localeCompare(y[1]||"");
    if(a!==0) return a;
    return (x[4]||"").localeCompare(y[4]||"");
  });

  LSJ("confErros", divergRows);

  if(!divergRows.length){
    $("#tbConf").innerHTML = `<div class="muted">✅ Não há divergências.</div>`;
    toast("Não há divergências.");
    return;
  }

  $("#tbConf").innerHTML = renderTable(
    ["Local","Código","Descrição","Grade 1","Grade 2","Grade 3","Diferença (Plan2 - Plan1)"],
    divergRows,
    { highlightFn: (r)=> Number(r[6]) !== 0 }
  );

  toast(`Comparação concluída. Divergências: ${divergRows.length}`);
}

  function limparConferencia(){
    $("#txCad").value=""; $("#txInf").value=""; $("#tbConf").innerHTML="";
    LSJ("confErros", []);
    toast("Limpo.");
  }

function baixarErrosConferencia(){
  const erros = LSJ("confErros") || [];
  if(!erros.length){
    toast("Sem divergências para baixar.", false);
    return;
  }

  // TXT em TAB (fica perfeito pra colar no Excel)
  const txt = erros.map(r => r.join("\t")).join("\r\n") + "\r\n";

  const blob = new Blob([txt], {type:"text/plain;charset=utf-8"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "divergencias_comparacao.txt";
  a.click();
  URL.revokeObjectURL(a.href);

  toast("TXT de divergências baixado.");
}

function conferirProducao(){
  const rows = parseLines($("#txProdA").value);
  if(!rows.length){
    toast("Cole a planilha de estoque.", false);
    return;
  }

  // Remove linhas inválidas, vazias ou com "-"
  const dados = rows
    .filter(r => r && r.length >= 7)
    .filter(r => (r[0] || "").toString().trim() !== "-")
    .map(r => ({
      local: (r[0] ?? "").toString().trim(),
      codigo: (r[1] ?? "").toString().trim(),
      descricao: (r[2] ?? "").toString().trim(),
      g1: (r[3] ?? "").toString().trim(),
      g2: (r[4] ?? "").toString().trim(),
      g3: (r[5] ?? "").toString().trim(),
      qtd: Number(((r[6] ?? "0").toString().trim()).replace(/\./g,"").replace(",", ".")) || 0
    }))
    .filter(x => x.local && x.codigo);

  if(!dados.length){
    toast("Nenhuma linha válida encontrada.", false);
    return;
  }

  // Descobre o local padrão por código:
  // regra = local com maior quantidade total daquele código
  const mapaCodigoLocal = new Map();

  for(const item of dados){
    if(!mapaCodigoLocal.has(item.codigo)){
      mapaCodigoLocal.set(item.codigo, new Map());
    }
    const locMap = mapaCodigoLocal.get(item.codigo);
    locMap.set(item.local, (locMap.get(item.local) || 0) + item.qtd);
  }

  function getLocalCorreto(codigo){
    const locMap = mapaCodigoLocal.get(codigo);
    if(!locMap) return "";

    let melhorLocal = "";
    let maiorQtd = -1;

    for(const [local, qtd] of locMap.entries()){
      if(qtd > maiorQtd){
        maiorQtd = qtd;
        melhorLocal = local;
      }
    }

    return melhorLocal;
  }

  const divergencias = [];

  for(const item of dados){
    const localCorreto = getLocalCorreto(item.codigo);

    if(localCorreto && item.local !== localCorreto){
      divergencias.push([
        item.local,
        localCorreto,
        item.codigo,
        item.descricao,
        item.g1,
        item.g2,
        item.g3,
        item.qtd
      ]);
    }
  }

  divergencias.sort((a,b)=>{
    const c1 = (a[2] || "").localeCompare(b[2] || "");
    if(c1 !== 0) return c1;
    return (a[0] || "").localeCompare(b[0] || "");
  });

  LSJ("confEstoqueErros", divergencias);

  if(!divergencias.length){
    $("#tbProd").innerHTML = `<div class="muted">✅ Nenhuma divergência de local encontrada.</div>`;
    toast("Nenhuma divergência encontrada.");
    return;
  }

  $("#tbProd").innerHTML = renderTable(
    ["Local informado","Local correto","Código","Descrição","Grade 1","Grade 2","Grade 3","Quantidade"],
    divergencias,
    { highlightFn: () => true }
  );

  toast(`Análise concluída. Divergências encontradas: ${divergencias.length}`);
}

function limparProducao(){
  $("#txProdA").value = "";
  $("#tbProd").innerHTML = "";
  LSJ("confEstoqueErros", []);
  toast("Limpo.");
}

  // Admin
  function salvarEmail(){ LS("email", $("#adEmail").value||""); toast("Email salvo."); }
  function carregarEmail(){ $("#adEmail").value = LS("email")||""; toast("Email carregado."); }
  function resetTudo(){
    if(!confirm("Tem certeza? Isso apaga tudo salvo no navegador.")) return;
    localStorage.clear();
    setupUI();
  }
  
function limparBateuFuturo(){
  const bateu = LSJ("bateu") || {};
  const hoje = hojeKey();

  for(const key in bateu){
    if(key > hoje){
      delete bateu[key];
    }
  }

  LSJ("bateu", bateu);
}
  
  // ---------- Init ----------
  document.addEventListener("DOMContentLoaded", ()=>{
    // Puxar dados salvos
    $("#txManual").value = LS("manual")||"";
    const exs = LSJ("exs");
if(exs){
  $("#exSaldo").value = exs.saldo ?? 0;
  $("#exEntrada").value = exs.entrada ?? 0;
  $("#exSaida").value = exs.saida ?? 0;
  $("#exRealInput").value = exs.real ?? 0;
  $("#exAjuste").value = exs.ajuste ?? 0;
  calcEXS();
}

    // Login UI
    $("#btnLogin").onclick = ()=> login($("#lgUser").value.trim(), $("#lgPass").value);
    $("#btnLogout").onclick = logout;
    $("#btnCreate").onclick = ()=> toggleBox("createBox", true);
    $("#btnRecover").onclick = ()=> toggleBox("recoverBox", true);

    $("#btnDoCreate").onclick = ()=>{
      const user = $("#crUser").value.trim();
      const pass = $("#crPass").value;
      const email = $("#crEmail").value.trim();
      if(!user || !pass){ toast("Preencha usuário e senha.", false); return; }
      const users = getUsers();
      if(users.some(x=>x.user===user)){ toast("Usuário já existe.", false); return; }
      users.push({user, pass, email});
      setUsers(users);
      toast("Conta criada. Você já pode entrar.");
      toggleBox("createBox", false);
    };

    $("#btnDoRecover").onclick = ()=>{
      const user = $("#rcUser").value.trim();
      const u = getUsers().find(x=>x.user===user);
      if(!u){ toast("Usuário não encontrado.", false); return; }
      toast(`Conta encontrada. Email registrado: ${u.email || "(sem email)"} (senha não é enviada aqui).`);
      toggleBox("recoverBox", false);
    };

    setupUI();
limparBateuFuturo();
    const v = (location.hash||"#inicio").replace("#","");
    setView(v);
    if(!LS("exs_selected_day")){
  LS("exs_selected_day", hojeKey());
}
carregarResumoDoDia(LS("exs_selected_day"));
montarCalendario();

    // Register SW
    if("serviceWorker" in navigator){
      navigator.serviceWorker.register("./sw.js")
        .then(()=>console.log("SW ok"))
        .catch(()=>console.log("SW falhou"));
    }
  });
</script>
